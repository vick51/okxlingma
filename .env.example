# ====================================
# OKX量化交易系统 - 环境配置
# ====================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 填写您的实际配置信息
# 3. 不要将 .env 文件提交到 Git

# ====================================
# OKX API配置（必填）
# ====================================
OKX_API_KEY=your_api_key_here
OKX_SECRET_KEY=your_secret_key_here
OKX_PASSPHRASE=your_passphrase_here

# ====================================
# 交易配置（可选，有默认值）
# ====================================
# 交易对（永续合约格式）
SYMBOL=BTC/USDT:USDT

# 每次开仓数量
ORDER_SIZE=0.002

# 杠杆倍数（建议：1-125）
LEVERAGE=50

# 价格间隔阈值（USDT）
PRICE_GAP=1000

# ====================================
# 邮件配置（可选）
# ====================================
# SMTP服务器地址
SMTP_SERVER=smtp-mail.outlook.com

# SMTP端口
SMTP_PORT=587

# 发件人邮箱
EMAIL_USER=your_email@outlook.com

# 邮箱密码（Outlook需使用应用专用密码）
EMAIL_PASSWORD=your_app_password

# 收件人邮箱
EMAIL_RECIPIENT=vick0515@outlook.com

# ====================================
# Web配置（可选）
# ====================================
# Web服务端口
WEB_PORT=5000

# Flask运行主机
FLASK_HOST=0.0.0.0

# 调试模式（生产环境请设为false）
FLASK_DEBUG=false

# ====================================
# 日志配置（可选）
# ====================================
# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 单个日志文件最大大小（字节）
LOG_MAX_BYTES=10485760

# 保留的日志文件数量
LOG_BACKUP_COUNT=5
